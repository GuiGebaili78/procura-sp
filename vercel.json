{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm ci",
  "functions": {
    "src/app/api/**/*.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "env": {
    "NODE_ENV": "production",
    "NEON_HOST": "@neon-host",
    "NEON_USER": "@neon-user", 
    "NEON_DATABASE": "@neon-database",
    "NEON_PASSWORD": "@neon-password"
  }
}
